              "id": "e7049507-d4d4-4a24-9f11-72c83787883e",
              "name": "icp_prompt",
              "value": "Find B2B companies in Nashik, Maharashtra, India in the  Manufacturing, Engineering, Defense supply chain, or  Industrial Automation sector. Target companies with  10-200 employees. Find decision makers (Owner, CEO,  Director, Head of Operations, Purchase Manager).  Research their recent projects, pain points, and current  challenges. Then write a highly personalized cold email  from Owais, an AI automation consultant, offering to  automate their lead generation and outreach process  to save time and increase qualified leads.",
              "type": "string"
            },
            {
              "id": "7ab08ceb-d24d-4337-bb3b-0bcbe37075a6",
              "name": "max_companies",
              "value": 5,
              "type": "number"
            }
          ]
        },
        "options": {}
      },
